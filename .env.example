# 复制本文件为 .env，然后填写自己的真实配置。
# 不要把真实 .env 提交到 Git。

# =========================
# 火山方舟 OpenAI-compatible API
# =========================
OPENAI_API_KEY=your_volcengine_ark_api_key_here
OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_MODEL=your_ark_endpoint_id_here
LLM_ENABLED=1
LLM_DEBUG=0
LLM_TEMPERATURE=0.2
LLM_DEFAULT_SPEED=40
LLM_DEFAULT_DURATION=0.8

# =========================
# Web/API
# =========================
APP_WEB_PORT=6500
APP_API_PORT=6501
APP_DEBUG=0

# =========================
# Rosmaster 硬件
# =========================
ROSMASTER_PORT=/dev/ttyUSB0
ROSMASTER_CAR_TYPE=1
ROSMASTER_CAMERA_DEVICE=/dev/video0
ROSMASTER_VIDEO_WIDTH=640
ROSMASTER_VIDEO_HEIGHT=480
ROSMASTER_VIDEO_FPS=20
ROSMASTER_VIDEO_QUALITY=80
ROSMASTER_WATCHDOG_TIMEOUT=3.0

# =========================
# 语音识别
# =========================
VOICE_ASR_BACKEND=local
VOICE_MODEL_SIZE=tiny
VOICE_SAMPLE_RATE=16000
VOICE_SILENCE_DURATION=0.4
VOICE_SILENCE_THRESHOLD=0.015
VOICE_MAX_DURATION=10
VOICE_INPUT_DEVICE=
VOICE_DEBUG=0

# =========================
# TTS 播报
# =========================
TTS_BACKEND=edge
TTS_VOICE=zh-CN-XiaoxiaoNeural

# =========================
# 人物追踪
# =========================
TRACK_MODEL_PATH=yolov8n.pt
TRACK_CONF_THRES=0.4
TRACK_DEADZONE=40
TRACK_PID_P=0.003
TRACK_DEBUG=0
